# ========================================
# MeetSum AI - 本地开发环境配置
# ========================================
# 使用说明：
# 1. 从 .env.example 复制并重命名为此文件
# 2. 填写下方各服务的API密钥
# 3. 首次运行需要先在Supabase执行 schema.sql

# ===================
# Supabase 配置
# ===================
# 获取地址: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===================
# OpenAI 配置
# ===================
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ===================
# Stripe 配置 (可选，支付功能)
# ===================
# 获取地址: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_PRO_PRICE_ID=price_your-pro-price-id
STRIPE_TEAM_PRICE_ID=price_your-team-price-id

# ===================
# 应用配置
# ===================
NEXT_PUBLIC_APP_URL=http://localhost:3000
