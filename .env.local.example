# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI API Keys (At least one required)
OPENAI_API_KEY=sk-your-openai-key
OPENROUTER_API_KEY=sk-or-v1-...
DEEPSEEK_API_KEY=sk-...
ZHIPU_API_KEY=...
DOUBAO_API_KEY=...
JINA_API_KEY=...

# Default AI Provider
DEFAULT_AI_PROVIDER=deepseek

# App URL
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# Stripe (Optional)
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

# ============================================
# AI Native Architecture - New Environment Variables
# 基于YC Tom Blomfield演讲优化方案
# ============================================

# SendGrid (Email system)
SENDGRID_API_KEY=SG.xxx...                          # SendGrid API Key (Settings → API Keys)
SENDGRID_FROM_EMAIL=noreply@yourdomain.com       # 发送邮箱（需验证域名）
SENDGRID_WEBHOOK_SECRET=your-webhook-secret       # Webhook签名验证密钥（可选）

# Twitter (X) API
TWITTER_BEARER_TOKEN=AAAAAAAAxxx...               # Twitter API v2 Bearer Token
TWITTER_API_KEY=xxx...                            # Twitter API Key (Optional)
TWITTER_API_SECRET=xxx...                        # Twitter API Secret (Optional)

# Reddit API
REDDIT_CLIENT_ID=xxx...                          # Reddit App Client ID
REDDIT_CLIENT_SECRET=xxx...                      # Reddit App Client Secret
REDDIT_USER_AGENT=MeetSumAI/1.0 (by /u/yourusername)  # Reddit User-Agent

# AI Decision Engine (AI决策引擎)
AI_DECISION_MODEL=deepseek-chat                 # 用于AI决策的模型
AI_DECISION_CONFIDENCE_THRESHOLD=0.8           # 置信度阈值（高于此值自动执行）
AI_DECISION_HUMAN_APPROVAL_ENABLED=true        # 是否启用人工审批

# AI Learning System (AI学习系统)
AI_LEARNING_ENABLED=true                        # 是否启用AI学习
AI_LEARNING_RATE=0.01                          # 学习率（用于调整AI策略）
AI_LEARNING_LOG_RETENTION_DAYS=90             # 学习日志保留天数

# Monitoring & Analytics (监控与分析)
SENTRY_DSN=https://xxx@sentry.io/xxx          # Sentry错误监控
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX              # Google Analytics ID
VERCEL_ANALYTICS_ID=xxxxxxxx-xxxx-xxxx-xxxx    # Vercel Analytics ID (Optional)

# Cache & Performance (缓存与性能)
REDIS_URL=redis://localhost:6379                  # Redis URL (Optional, for caching)
CACHE_TTL_SECONDS=3600                          # 缓存TTL（秒）

# Feature Flags (功能开关)
FEATURE_AI_AUTO_REPLY_ENABLED=false             # AI自动回复开关
FEATURE_AI_DECISION_ENABLED=true               # AI决策引擎开关
FEATURE_SOCIAL_MONITORING_ENABLED=true         # 社交媒体监控开关
FEATURE_USER_BEHAVIOR_TRACKING_ENABLED=true  # 用户行为追踪开关

# Security (安全)
WEBHOOK_SECRET=your-webhook-secret-xxx          # Webhook签名验证密钥
API_RATE_LIMIT_PER_MINUTE=60                    # API速率限制（每分钟请求数）
