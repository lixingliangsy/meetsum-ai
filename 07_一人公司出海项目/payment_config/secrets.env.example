# ============================================================
# Waffo 支付密钥模板  ——  复制为 secrets.env 并填入你的真实凭证
# ============================================================
# 使用方法：
#   1. 本文件复制一份，命名为 secrets.env（同目录）
#   2. 把右侧占位符替换成你在 Waffo Dashboard 拿到的真实值
#   3. 运行：python setup_payment_env.py
#   脚本会为所有「已接支付(checkout+webhook)」的产品批量写入 Vercel 环境变量
#
# ⚠️ 安全：secrets.env 含私钥，已被 .gitignore 排除，切勿提交到 git
# ============================================================

# ---- Waffo 商户凭证（在 Waffo Dashboard → 开发者中心 → API 管理 获取）----
WAFFO_MERCHANT_ID=MCH_xxxxxxxxxx
WAFFO_PRIVATE_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_WAFFO_PUBLIC_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WAFFO_API_BASE_URL=https://api.waffo.com/v1
WAFFO_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- 应用基础 URL（每个产品不同，部署后从 Vercel 控制台复制）----
# 下面列出已接支付的 4 个产品，按需替换；其余产品上线后可追加
NEXT_PUBLIC_APP_URL_CALORIE_TRACKER=https://calorie-tracker.vercel.app
NEXT_PUBLIC_APP_URL_AI_FITNESS_PLANNER=https://ai-fitness-planner.vercel.app
NEXT_PUBLIC_APP_URL_ARTICLESUMM_PRO=https://articlesumm-pro.vercel.app
NEXT_PUBLIC_APP_URL_FITNESS_CHALLENGE_TRACKER=https://fitness-challenge-tracker.vercel.app
NEXT_PUBLIC_APP_URL_FITNESS_GAMIFICATION=https://fitness-gamification-platform.vercel.app
