# Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# ============================================
# Vercel Deployment
# ============================================
VERCEL_TOKEN=your_vercel_token_here
VERCEL_TEAM_ID=your_vercel_team_id_here

# ============================================
# OpenAI API (for article quality improvement)
# ============================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# ============================================
# LinkedIn API (for auto-publishing)
# ============================================
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_PERSON_URN=your_linkedin_person_urn_here

# ============================================
# Google Search Console API (optional)
# ============================================
GOOGLE_SEARCH_CONSOLE_KEY=your_google_api_key_here

# ============================================
# Instructions
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and replace placeholder values with real API keys
# 3. Never commit .env to Git (it's in .gitignore)
# 4. Keep your API keys secure!
